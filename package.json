{
  "name": "server-workspace",
  "displayName": "Server Workspace",
  "description": "Kleine Remote-SSH Workspace-Hilfe fuer Systemstatus, Notizen, Datei-Tracking und Server-Merkliste.",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onView:serverWorkspace.work",
    "onView:serverWorkspace.system",
    "onView:serverWorkspace.notes",
    "onView:serverWorkspace.servers",
    "onCommand:serverWorkspace.initialize",
    "onCommand:serverWorkspace.refresh",
    "onCommand:serverWorkspace.openNotes",
    "onCommand:serverWorkspace.openSystemStatus",
    "onCommand:serverWorkspace.openFile",
    "onCommand:serverWorkspace.trackCurrentFile",
    "onCommand:serverWorkspace.editComment",
    "onCommand:serverWorkspace.deleteComment",
    "onCommand:serverWorkspace.copyPath",
    "onCommand:serverWorkspace.updateMetadata",
    "onCommand:serverWorkspace.copyHost",
    "onCommand:serverWorkspace.saveCurrentServer",
    "onCommand:serverWorkspace.renameServer"
  ],
  "contributes": {
    "commands": [
      {
        "command": "serverWorkspace.initialize",
        "title": "Server Workspace: Initialisieren"
      },
      {
        "command": "serverWorkspace.refresh",
        "title": "Server Workspace: Aktualisieren"
      },
      {
        "command": "serverWorkspace.openNotes",
        "title": "Server Workspace: Notizen oeffnen"
      },
      {
        "command": "serverWorkspace.openSystemStatus",
        "title": "Server Workspace: Systemstatus oeffnen"
      },
      {
        "command": "serverWorkspace.openFile",
        "title": "Server Workspace: Datei oeffnen"
      },
      {
        "command": "serverWorkspace.trackCurrentFile",
        "title": "Server Workspace: Aktuelle Datei tracken"
      },
      {
        "command": "serverWorkspace.editComment",
        "title": "Server Workspace: Kommentar bearbeiten"
      },
      {
        "command": "serverWorkspace.deleteComment",
        "title": "Server Workspace: Kommentar loeschen"
      },
      {
        "command": "serverWorkspace.copyPath",
        "title": "Server Workspace: Pfad kopieren"
      },
      {
        "command": "serverWorkspace.updateMetadata",
        "title": "Server Workspace: Metadaten aktualisieren"
      },
      {
        "command": "serverWorkspace.copyHost",
        "title": "Server Workspace: Host/IP kopieren"
      },
      {
        "command": "serverWorkspace.saveCurrentServer",
        "title": "Server Workspace: Server speichern"
      },
      {
        "command": "serverWorkspace.renameServer",
        "title": "Server Workspace: Anzeigename bearbeiten"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "serverWorkspace",
          "title": "Server Workspace",
          "icon": "resources/server-workspace.svg"
        }
      ]
    },
    "views": {
      "serverWorkspace": [
        {
          "id": "serverWorkspace.work",
          "name": "Arbeitsseite"
        },
        {
          "id": "serverWorkspace.system",
          "name": "System"
        },
        {
          "id": "serverWorkspace.notes",
          "name": "Notizen"
        },
        {
          "id": "serverWorkspace.servers",
          "name": "Server"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "serverWorkspace.openFile",
          "when": "false"
        },
        {
          "command": "serverWorkspace.copyPath",
          "when": "false"
        },
        {
          "command": "serverWorkspace.deleteComment",
          "when": "false"
        },
        {
          "command": "serverWorkspace.openSystemStatus",
          "when": "false"
        },
        {
          "command": "serverWorkspace.renameServer",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "serverWorkspace.initialize",
          "when": "view == serverWorkspace.work || view == serverWorkspace.system || view == serverWorkspace.notes",
          "group": "navigation"
        },
        {
          "command": "serverWorkspace.refresh",
          "when": "view == serverWorkspace.work || view == serverWorkspace.system",
          "group": "navigation"
        },
        {
          "command": "serverWorkspace.trackCurrentFile",
          "when": "view == serverWorkspace.work",
          "group": "navigation"
        },
        {
          "command": "serverWorkspace.openNotes",
          "when": "view == serverWorkspace.notes",
          "group": "navigation"
        },
        {
          "command": "serverWorkspace.saveCurrentServer",
          "when": "view == serverWorkspace.servers",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "serverWorkspace.openFile",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "inline@1"
        },
        {
          "command": "serverWorkspace.editComment",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@1"
        },
        {
          "command": "serverWorkspace.deleteComment",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "2_edit@2"
        },
        {
          "command": "serverWorkspace.copyPath",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "3_copy@1"
        },
        {
          "command": "serverWorkspace.updateMetadata",
          "when": "view == serverWorkspace.work && viewItem == trackedFile",
          "group": "4_refresh@1"
        },
        {
          "command": "serverWorkspace.openFile",
          "when": "view == serverWorkspace.work && viewItem == logEntry",
          "group": "inline@1"
        },
        {
          "command": "serverWorkspace.copyHost",
          "when": "view == serverWorkspace.servers && viewItem == savedServer",
          "group": "inline@1"
        },
        {
          "command": "serverWorkspace.saveCurrentServer",
          "when": "view == serverWorkspace.servers && viewItem == savedServer",
          "group": "2_edit@1"
        },
        {
          "command": "serverWorkspace.renameServer",
          "when": "view == serverWorkspace.servers && viewItem == savedServer",
          "group": "2_edit@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.4.5"
  }
}
